# Legacy-compatible database configuration
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bdta
DB_USER=bdta_user
DB_PASSWORD=your_mysql_password

# Optional TypeScript-native database override
# DATABASE_URL=mysql://bdta_user:your_mysql_password@localhost:3306/bdta

# Optional runtime overrides
SESSION_LIFETIME_SECONDS=1209600
# HOST=0.0.0.0
# PORT=3000
# JOB_POLL_INTERVAL_MS=30000
# JOB_BATCH_SIZE=25
# EMAIL_BATCH_SIZE=25

# Provider/base URL settings are managed through Admin > Settings and stored in MySQL:
# base_url
# stripe_enabled / stripe_mode / stripe_live_secret_key / stripe_test_secret_key
# turnstile_site_key / turnstile_secret_key
# imap_enabled / imap_host
# smtp_host
# google_oauth_client_id / google_oauth_client_secret
