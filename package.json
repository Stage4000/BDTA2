{
  "name": "bdta-refactor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start:api": "node dist/apps/api/src/main.js",
    "start:jobs": "node dist/apps/jobs/src/main.js",
    "start:migrate": "node dist/apps/migrate/src/main.js",
    "start:web": "node dist/apps/web/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "mysql2": "^3.15.3",
    "zod": "^3.25.76"
  }
}
